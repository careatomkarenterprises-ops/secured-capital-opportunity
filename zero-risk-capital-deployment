    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.5;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .hero {
            background: linear-gradient(135deg, #0b1e33 0%, #143b5c 100%);
            color: white;
            padding: 60px 0;
            position: relative;
            overflow: hidden;
        }

        .hero::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 300px;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05));
            transform: skewX(-15deg);
        }

        .hero-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
            position: relative;
            z-index: 2;
        }

        .hero h1 {
            font-size: 48px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 20px;
        }

        .hero .highlight {
            color: #fbbf24;
            font-size: 20px;
            font-weight: 500;
            margin-bottom: 30px;
        }

        .confidential-badge {
            background: rgba(239, 68, 68, 0.2);
            border: 2px solid #ef4444;
            color: #fecaca;
            padding: 8px 24px;
            border-radius: 40px;
            display: inline-block;
            font-weight: 600;
            letter-spacing: 2px;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .hero-stats {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .hero-stats .stat {
            text-align: center;
            padding: 15px;
        }

        .hero-stats .stat .value {
            font-size: 42px;
            font-weight: 700;
            color: #fbbf24;
        }

        .hero-stats .stat .label {
            font-size: 14px;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.05);
            margin-top: -40px;
            position: relative;
            z-index: 10;
            margin-bottom: 40px;
        }

        .stat-card {
            text-align: center;
        }

        .stat-card .number {
            font-size: 36px;
            font-weight: 700;
            color: #0b1e33;
            margin-bottom: 5px;
        }

        .stat-card .label {
            color: #475569;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-card .note {
            color: #64748b;
            font-size: 12px;
            margin-top: 5px;
        }

        .section {
            padding: 60px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .section-title {
            font-size: 32px;
            font-weight: 700;
            color: #0b1e33;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .section-title .number {
            background: #0b1e33;
            color: white;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 600;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #e2e8f0;
        }

        .card-accent {
            background: linear-gradient(135deg, #0b1e33 0%, #1e4a76 100%);
            color: white;
        }

