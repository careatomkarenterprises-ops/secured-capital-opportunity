            content: "⚠️ Pro-rata (20 days)";
            position: absolute;
            top: -8px;
            right: 5px;
            background: #dc2626;
            color: white;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 12px;
            font-weight: 600;
